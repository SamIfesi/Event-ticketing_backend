{
  "health": [{ "method": "GET", "endpoint": "/api/health" }],
  "auth": [
    { "method": "POST", "endpoint": "/api/auth/register" },
    { "method": "POST", "endpoint": "/api/auth/login" },
    { "method": "POST", "endpoint": "/api/auth/logout" },
    { "method": "GET", "endpoint": "/api/auth/me" },
    { "method": "POST", "endpoint": "/api/auth/verify-email" },
    { "method": "POST", "endpoint": "/api/auth/resend-otp" },
    { "method": "POST", "endpoint": "/api/auth/forgot-password" },
    { "method": "POST", "endpoint": "/api/auth/verify-forgot-otp" },
    { "method": "POST", "endpoint": "/api/auth/reset-password" }
  ],
  "profile": [
    { "method": "GET", "endpoint": "/api/profile" },
    { "method": "PUT", "endpoint": "/api/profile" },
    { "method": "POST", "endpoint": "/api/profile/change-password" },
    { "method": "POST", "endpoint": "/api/profile/change-email" },
    { "method": "POST", "endpoint": "/api/profile/confirm-email-change" },
    { "method": "GET", "endpoint": "/api/profile/bookings" },
    { "method": "GET", "endpoint": "/api/profile/tickets" },
    { "method": "GET", "endpoint": "/api/profile/activity" }
  ],
  "events": [
    { "method": "GET", "endpoint": "/api/events" },
    { "method": "GET", "endpoint": "/api/events/:id" },
    { "method": "POST", "endpoint": "/api/events" },
    { "method": "PUT", "endpoint": "/api/events/:id" },
    { "method": "DELETE", "endpoint": "/api/events/:id" },
    { "method": "GET", "endpoint": "/api/organizer/events" }
  ],
  "bookings": [
    { "method": "POST", "endpoint": "/api/bookings" },
    { "method": "POST", "endpoint": "/api/bookings/verify" },
    { "method": "GET", "endpoint": "/api/bookings/mine" },
    { "method": "GET", "endpoint": "/api/bookings/:id" },
    { "method": "GET", "endpoint": "/api/organizer/events/:id/bookings" }
  ],
  "tickets": [
    { "method": "GET", "endpoint": "/api/tickets/:id" },
    { "method": "GET", "endpoint": "/api/tickets/booking/:bookingId" },
    { "method": "POST", "endpoint": "/api/tickets/checkin" },
    { "method": "GET", "endpoint": "/api/organizer/events/:id/checkins" }
  ],
  "categories": [
    { "method": "GET", "endpoint": "/api/categories" },
    { "method": "GET", "endpoint": "/api/categories/:id" },
    { "method": "POST", "endpoint": "/api/categories" },
    { "method": "PUT", "endpoint": "/api/categories/:id" },
    { "method": "DELETE", "endpoint": "/api/categories/:id" }
  ],
  "organizer_applications": [
    { "method": "POST", "endpoint": "/api/org_applications" },
    { "method": "GET",  "endpoint": "/api/org_applications/mine" },
    { "method": "GET",  "endpoint": "/api/admin/org_applications" },
    { "method": "PUT",  "endpoint": "/api/admin/org_applications/:id/approve" },
    { "method": "PUT",  "endpoint": "/api/admin/org_applications/:id/reject" }
  ],
  "admin": [
    { "method": "GET", "endpoint": "/api/admin/stats" },
    { "method": "GET", "endpoint": "/api/admin/users" },
    { "method": "GET", "endpoint": "/api/admin/users/:id" },
    { "method": "PUT", "endpoint": "/api/admin/users/:id/role" },
    { "method": "PUT", "endpoint": "/api/admin/users/:id/status" },
    { "method": "GET", "endpoint": "/api/admin/events" },
    { "method": "PUT", "endpoint": "/api/admin/events/:id/status" }
  ],
  "dev": [
    { "method": "GET", "endpoint": "/api/dev/overview" },
    { "method": "GET", "endpoint": "/api/dev/users" },
    { "method": "GET", "endpoint": "/api/dev/logs" },
    { "method": "GET", "endpoint": "/api/dev/logs/:id" },
    { "method": "DELETE", "endpoint": "/api/dev/logs" },
    { "method": "POST", "endpoint": "/api/dev/users/:id/role" },
    { "method": "GET", "endpoint": "/api/dev/bookings/failed" },
    { "method": "POST", "endpoint": "/api/dev/bookings/:id/force-pay" }
  ],
  "notifications": [
    {
      "method": "GET",
      "endpoint": "/api/notifications",
      "auth": "any",
      "description": "Paginated list. ?unread=1 to filter."
    },
    {
      "method": "GET",
      "endpoint": "/api/notifications/unread",
      "auth": "any",
      "description": "Unread count only — poll for bell badge."
    },
    {
      "method": "PUT",
      "endpoint": "/api/notifications/:id/read",
      "auth": "any",
      "description": "Mark one notification as read."
    },
    {
      "method": "PUT",
      "endpoint": "/api/notifications/read-all",
      "auth": "any",
      "description": "Mark all notifications as read."
    },
    {
      "method": "DELETE",
      "endpoint": "/api/notifications/:id",
      "auth": "any",
      "description": "Delete one notification."
    }
  ],
  "transactions": [
    {
      "method": "GET",
      "endpoint": "/api/transactions/mine",
      "auth": "attendee",
      "description": "Own payment history."
    },
    {
      "method": "GET",
      "endpoint": "/api/organizer/transactions",
      "auth": "organizer/dev",
      "description": "Revenue ledger. ?event_id=&type=&from=&to="
    },
    {
      "method": "GET",
      "endpoint": "/api/admin/transactions",
      "auth": "admin/dev",
      "description": "Platform-wide audit log. Full filters."
    },
    {
      "method": "GET",
      "endpoint": "/api/admin/transactions/summary",
      "auth": "admin/dev",
      "description": "Financial KPIs. ?from=&to= (defaults to current month)."
    },
    {
      "method": "GET",
      "endpoint": "/api/admin/transactions/:bookingId",
      "auth": "admin/dev",
      "description": "Full audit trail for a single booking."
    }
  ]
}